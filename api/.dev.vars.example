# Prerequisites: Docker + Supabase CLI. Run `supabase start` first, then `supabase status` for values.
# Copy to .dev.vars for local Wrangler dev (`pnpm dev` in api/).
# Values come from `supabase status` (or `supabase status -o env`) after `supabase start`.
# For production, set these as Worker secrets in the Cloudflare dashboard (or via wrangler secret).

SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Typesense variables
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
TYPESENSE_API_KEY=

# Frontend origin for CORS (Vite dev server)
APP_URL=http://localhost:3000

# Rate limiting: RATE_LIMIT_KV is bound in wrangler.jsonc, not here,
# since it's a KV namespace, not a secret. Create it locally with:
#   pnpm --filter api exec wrangler kv namespace create RATE_LIMIT_KV
# Then paste the printed id into wrangler.jsonc. Without it, wrangler dev
# falls back to in-memory counters (reset on every restart).